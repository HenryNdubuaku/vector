# A byte-level GPT trained on Shakespeare: two transformer blocks, multi-head
# attention, layernorm and adam, all written in vector.

vocab = 256
t = 64
c = 64
h = 4
hd = 16
batch = 16
chunk = 100
rounds = 20
lr = 0.001
sample_len = 300

data = load("https://raw.githubusercontent.com/karpathy/char-rnn/master/data/tinyshakespeare/input.txt")
n = 1115394

fn lnr(env, row):
  (row - mean(row)) / sqrt(var(row) + 0.00001) * env.g + env.d

fn mm(env, w):
  matmul(env.x, w)

fn qk(q, k):
  matmul(q, transpose(k))

fn sm(row):
  softmax(row)

fn rows_sm(m):
  vmap(sm, m)

fn av(a, v):
  matmul(a, v)

fn attend(p, ctx, x):
  q = vmap(mm, {x: x}, p.wq)
  k = vmap(mm, {x: x}, p.wk)
  v = vmap(mm, {x: x}, p.wv)
  scores = vmap(qk, q, k) * ctx.scale + ctx.mask
  att = vmap(rows_sm, scores)
  heads = vmap(av, att, v)
  sum(vmap(av, heads, p.wo), 0)

module Block(t, c, h, hd):
  wq = reshape(glorot_uniform(h * c, hd), h, c, hd)
  wk = reshape(glorot_uniform(h * c, hd), h, c, hd)
  wv = reshape(glorot_uniform(h * c, hd), h, c, hd)
  wo = reshape(glorot_uniform(h * hd, c), h, hd, c)
  w1 = glorot_uniform(c, 4 * c)
  d1 = zeros(4 * c)
  w2 = glorot_uniform(4 * c, c)
  d2 = zeros(c)
  ga = zeros(c) + 1.0
  da = zeros(c)
  gm = zeros(c) + 1.0
  dm = zeros(c)

  forward(self, ctx, x):
    a = x + attend({wq: self.wq, wk: self.wk, wv: self.wv, wo: self.wo}, ctx, vmap(lnr, {g: self.ga, d: self.da}, x))
    a + matmul(relu(matmul(vmap(lnr, {g: self.gm, d: self.dm}, a), self.w1) + self.d1), self.w2) + self.d2

fn xent(logits, target):
  logsumexp(logits) - sum(one_hot(target, 256) * logits)

fn seq_logits(env, ids):
  x = take(env.m.wte, ids) + env.m.wpe
  x = env.m.b1(env.ctx, x)
  x = env.m.b2(env.ctx, x)
  matmul(vmap(lnr, {g: env.m.gf, d: env.m.df}, x), env.m.head)

fn seq_loss(env, ids, targets):
  mean(vmap(xent, seq_logits(env, ids), targets))

module Gpt(vocab, t, c, h, hd):
  wte = glorot_uniform(vocab, c)
  wpe = glorot_uniform(t, c) * 0.1
  b1 = Block(t, c, h, hd)
  b2 = Block(t, c, h, hd)
  gf = zeros(c) + 1.0
  df = zeros(c)
  head = glorot_uniform(c, vocab)

  forward(self, ctx, ids):
    seq_logits({m: self, ctx: ctx}, ids)

  loss(self, ctx, idsb, targetsb):
    mean(vmap(seq_loss, {m: self, ctx: ctx}, idsb, targetsb))

rows = matmul(reshape(arange(64.0), 64, 1), reshape(zeros(64) + 1.0, 1, 64))
ctx = {
  mask: where(rows >= transpose(rows), 0.0, 0.0 - 1000000000.0),
  scale: 1.0 / sqrt(16.0)
}

onerow = reshape(zeros(t) + 1.0, 1, t)
onecol = reshape(zeros(batch) + 1.0, batch, 1)
steps_row = matmul(onecol, reshape(arange(64.0), 1, t))

fn train_chunk(st, ctx, data, onerow, onecol, steps_row, r):
  s = st
  for step in 0..100:
    pos = floor(uniform(16) * 1115329.0)
    grid = matmul(reshape(pos, 16, 1), onerow) + steps_row
    flat = reshape(grid, 1024)
    idsb = reshape(take(data, flat), 16, 64)
    targetsb = reshape(take(data, flat + 1.0), 16, 64)
    g = grad(s.model.loss, ctx, idsb, targetsb)
    mo = 0.9 * s.mo + 0.1 * g
    vo = 0.999 * s.vo + 0.001 * g * g
    k = r * 100.0 + step + 1.0
    mh = mo / (1.0 - pow(0.9, k))
    vh = vo / (1.0 - pow(0.999, k))
    model = s.model - 0.001 * mh / (sqrt(vh) + 0.00000001)
    s = {model: model, mo: mo, vo: vo}
  s

model = Gpt(vocab, t, c, h, hd)
st = {model: model, mo: model * 0.0, vo: model * 0.0}

eval_ids = reshape(take(data, arange(1024.0)), 16, 64)
eval_targets = reshape(take(data, arange(1024.0) + 1.0), 16, 64)

for round in 0..20:
  st = train_chunk(st, ctx, data, onerow, onecol, steps_row, round)
  print(st.model.loss(ctx, eval_ids, eval_targets))

model = st.model
save(model, "gpt.safetensors")

window = data[:64]
gen = zeros(300)
for step in 0..300:
  logits = model(ctx, window)
  nxt = sample(logits[-1])
  window = concat(window[1:], reshape(nxt, 1))
  gen = gen + nxt * one_hot(step, 300)

print(text(data[:64]))
print(text(gen))
