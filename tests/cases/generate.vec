print(arange(5))
print(arange(2, 5))
print(arange(1.0, 2.0, 0.25))
print(arange(3, 0, -1))
print(reshape(arange(6), 2, 3))
print(sin(0.0))
print(cos(0.0))

fn s(x):
  sum(sin(x))

print(grad(s, [0.0, 0.0]))

fn r(x):
  sum(reshape(x, 4) * [1.0, 2.0, 3.0, 4.0])

print(grad(r, [[1.0, 1.0], [1.0, 1.0]]))
print(linspace(0.0, 1.0, 5))
half = 0.5
print(linspace(-half, half, 3))
n = 4.0
print(arange(n))
