function sq(x):
  sum(x * x)

function dsq(x):
  grad(sq, x)

print(grad(dsq, 3.0))

function stacked(x):
  sum([x, x] * [2.0, 3.0])

function dstacked(x):
  grad(stacked, x)

print(grad(dstacked, 5.0))

function cube(x):
  sum(x * x * x)

function dcube(x):
  grad(cube, x)

function ddcube(x):
  grad(dcube, x)

print(grad(dcube, 2.0))
print(grad(ddcube, 2.0))

function growth(x):
  sum(exp(x))

function dgrowth(x):
  grad(growth, x)

print(grad(dgrowth, 0.0))
