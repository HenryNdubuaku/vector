x = arange(10.0)
print(x[3.0])
print(x[2:5])
print(x[:3])
print(x[-3:])
print(x[[1.0, 4.0, 1.0]])

m = reshape(arange(6.0), 3, 2)
print(m[1])
print(m[1:3])

print(abs([0.0 - 3.0, 2.0]))
print(pow([2.0, 3.0], 2.0))
print(concat([1.0, 2.0], [3.0]))
print(stack([1.0, 2.0], [3.0, 4.0]))

fn f(x):
  sum(x[1:3] * 2.0 + pow(x[0], 2.0))

print(grad(f, [1.0, 2.0, 3.0]))
